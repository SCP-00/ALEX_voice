# ============================================
# Alex Voice — .gitignore
# No subir modelos LLM ni binarios descargables
# ============================================

# Modelos GGUF (grandes, descargar manualmente)
*.gguf
*.bin
*.safetensors

# llama.cpp (instalado aparte)
llama.cpp/

# Piper TTS (binarios descargables)
bin/piper/*.dll
bin/piper/*.exe
bin/piper/espeak-ng-data/
bin/piper/libtashkeel*
bin/piper/*.ort
bin/piper/piper/
bin/piper/piper_phonemize*

# Whisper
models/ggml-*.bin

# Descargas
*.zip
*.tar.gz

# Cache y temporales
/tmp/
tmp/
*.log
*.cache

# OS
.DS_Store
Thumbs.db
nul  # Windows reserved name artifact

# IDE
.idea/
.vscode/
*.swp

# Python
__pycache__/
*.pyc
*.pyo
venv/
.env
